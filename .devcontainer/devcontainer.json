{
    "name": "ROS2 - Humble",
    "privileged": true,
    "remoteUser": "ros2",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "USERNAME": "ros2"
        }
    },
    "workspaceFolder": "/home/ws",
    "customizations": {
        "vscode": {
            "extensions":[
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-themes",
                "twxs.cmake",
                "ms-iot.vscode-ros",
                "ms-python.python",
                "ms-vscode.cpptools-extension-pack"
            ]
        }
    },
    "mounts": [
        // "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
        "source=/dev/dri,target=/dev/dri,type=bind,consistency=cached",
        "source=${localWorkspaceFolder}/_cache/build,target=/home/ws/build,type=bind",
        "source=${localWorkspaceFolder}/_cache/install,target=/home/ws/install,type=bind",
        "source=${localWorkspaceFolder}/_cache/log,target=/home/ws/log,type=bind",
        "source=${localWorkspaceFolder}/_resources,target=/home/ws/_resources,type=bind",
        "source=${localWorkspaceFolder}/src,target=/home/ws/src,type=bind",
        "source=${localWorkspaceFolder}/README.md,target=/home/ws/README.md,type=bind"
    ],
    "containerEnv": {
        "DISPLAY": "host.docker.internal:0.0",
        "XDG_RUNTIME_DIR": "/tmp/runtime-ros2",
        "ROS_AUTOMATIC_DISCOVERY_RANGE": "LOCALHOST",
        "ROS_DOMAIN_ID": "0",
        "LIBGL_ALWAYS_INDIRECT": "0"
    },
    "runArgs": [
        // "--net=host",
        "--gpus=all",
        "-e",
        "DISPLAY=host.docker.internal:0.0",
        "-e",
        "XDG_RUNTIME_DIR=/tmp/runtime-ros2",
        "-e",
        "LIBGL_ALWAYS_INDIRECT=0"
    ],
    "postCreateCommand": "cat /home/ws/_resources/to_bash.txt >> ~/.bashrc && sudo chown -R $(whoami) /home/ws/ && sudo rosdep update && sudo apt update && sudo rosdep install --from-paths src _resources --ignore-src -y -r"
}